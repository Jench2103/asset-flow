        }
      }
    },
    "Reminders fire every %lld days at the time you set, starting at the next time of day after this setting is saved." : {
      "extractionState" : "stale",
      "localizations" : {
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "提醒會於您設定的時間每隔 %lld 天觸發一次，首次於設定儲存後的下一個指定時間點發出。"
          }
        }
      }
    },
    "Reminders fire on the chosen day of each month at the time you set. Only days 1–28 are offered to keep behavior consistent across all months." : {
      "extractionState" : "stale",
      "localizations" : {
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "提醒會在您選擇的每月日期與時間發出。為使所有月份的行為一致，僅提供 1 至 28 日可選。"
          }
        }
      }
    },
    "Unlock AssetFlow to access your portfolio data" : {
      "localizations" : {
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "解鎖 AssetFlow 以存取您的投資組合資料"
          }
        }
      }
    },
    "Weekly" : {
      "localizations" : {
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "每週"
          }
        }
      }
    },
    "When enabled, AssetFlow will require authentication after switching apps, locking the screen, or waking from sleep." : {
      "localizations" : {
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "啟用後，當您切換應用程式、鎖定螢幕或從睡眠喚醒時，AssetFlow 會要求驗證。"
          }
        }
      }
    }
