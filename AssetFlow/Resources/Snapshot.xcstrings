{
  "sourceLanguage" : "en",
  "strings" : {
    "Snapshot date cannot be in the future." : {
      "localizations" : {
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "快照日期不能是未來的日期。"
          }
        }
      }
    },
    "A snapshot already exists for %@. Go to the Snapshots screen to view and edit it." : {
      "localizations" : {
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ 已存在快照。請前往「快照」畫面檢視和編輯。"
          }
        }
      }
    },
    "'%@' already exists in this snapshot. Edit its value instead." : {
      "localizations" : {
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "「%@」已存在於此快照中，請直接編輯其數值。"
          }
        }
      }
    },
    "A cash flow operation with description '%@' already exists in this snapshot." : {
      "localizations" : {
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "描述為「%@」的現金流操作已存在於此快照中。"
          }
        }
      }
    },
    "Select Existing" : {
      "localizations" : {
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "選擇現有"
          }
        }
      }
    },
    "Create New" : {
      "localizations" : {
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "新建"
          }
        }
      }
    },
    "This Month" : {
      "localizations" : {
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "本月"
          }
        }
      }
    },
    "Previous 3 Months" : {
      "localizations" : {
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "前 3 個月"
          }
        }
      }
    },
    "Previous 6 Months" : {
      "localizations" : {
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "前 6 個月"
          }
        }
      }
    },
    "Previous Year" : {
      "localizations" : {
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "前一年"
          }
        }
      }
    },
    "Older" : {
      "localizations" : {
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "更早"
          }
        }
      }
    },
    "This asset has a value of 0. If the value hasn't been updated yet, please enter the current value. If the asset is no longer held, remove it from the snapshot to dismiss this warning." : {
      "localizations" : {
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "此資產的價值為 0。若尚未更新價值，請輸入目前的價值。若已不再持有此資產，請從快照中移除以關閉此警告。"
          }
        }
      }
    },
    "This snapshot contains assets with a value of 0." : {
      "localizations" : {
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "此快照包含價值為 0 的資產。"
          }
        }
      }
    },
    "At least one asset must be included in the snapshot." : {
      "localizations" : {
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "快照中必須包含至少一項資產。"
          }
        }
      }
    },
    "%lld assets will be saved with a value of 0. Continue?" : {
      "localizations" : {
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%lld 項資產的價值為 0，將一併儲存。是否繼續？"
          }
        }
      }
    }
  },
  "version" : "1.1"
}
